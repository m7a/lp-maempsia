{erl_opts, [debug_info]}.
{deps, [
	%{erlmpd, {git, "https://github.com/m7a/bo-erlmpd.git", {branch, "master"}}},
	%{jiffy, {git, "https://github.com/davisp/jiffy.git", {branch, "master"}}},
	%{mochiweb, "3.2.2"}
]}.
{relx, [
	{release, {maempsia, "0.0.1"}, [maempsia, sasl, erlmpd]},
        {mode, dev},
	{include_erts, false},
	{extended_start_script, true}
]}.
{shell, [
	{apps, [kernel, stdlib, sasl, mochiweb, erlmpd]}
]}.
